  "publicApiSurface": [
    "mkpsxiso - Build PlayStation ISO images from XML",
    "dumpsxiso - Extract and dump PlayStation ISO images",
    "mkpsxiso -h/--help - Show help text",
    "mkpsxiso -q/--quiet - Quiet mode",
    "mkpsxiso -l/--label - Specify volume ID",
    "mkpsxiso -o/--output - Specify output file",
    "mkpsxiso -c/--cuefile - Specify cue sheet file",
    "mkpsxiso -L/--license - Specify license file",
    "mkpsxiso -lba - Generate LBA location log",
    "mkpsxiso -lbahead - Generate C header with LBA locations",
    "mkpsxiso -noisogen - Calculate LBA without generating ISO",
    "mkpsxiso -noxa - Disable CD-XA attributes",
    "dumpsxiso -x/--extract - Extract files from ISO",
    "dumpsxiso -s/--xml - Specify output XML file",
    "dumpsxiso -e/--encoding - Specify audio encoding format",
    "dumpsxiso -pt/--path-table - Extract from path table",
    "dumpsxiso --force - Dump obfuscated ISOs",
    "dumpsxiso --noxml - Suppress XML generation",
    "dumpsxiso --raw - Dump files in raw format"
  ]
